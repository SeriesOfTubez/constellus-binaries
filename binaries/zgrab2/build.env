# zgrab2 — application-layer banner-grab scanner (zmap). Built from pinned source.
# Bump VERSION to upgrade; the pipeline re-runs govulncheck + Trivy before publishing.
REPO=https://github.com/zmap/zgrab2
VERSION=v1.0.0
PKG=./cmd/zgrab2
BIN=zgrab2
GO_VERSION=1.25
# Security dep overrides — reachable govulncheck findings patched in our build
# (space-separated module@version). Drop each when upstream zgrab2 bumps it:
#   GO-2026-5026 (golang.org/x/net idna) — zgrab2 v1.0.0 ships x/net v0.47.0; fixed in v0.55.0
GO_PATCHES=golang.org/x/net@v0.55.0
